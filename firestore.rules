rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── helpers ──────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // ── users ─────────────────────────────────────────────
    // Each user can only read/write their own profile doc
    match /users/{userId} {
      allow read, write: if isSignedIn() && isOwner(userId);
    }

    // ── visionBoard ───────────────────────────────────────
    // Documents have a `userId` field; only the owner can access them
    match /visionBoard/{docId} {
      allow read, write: if isSignedIn() && isOwner(resource.data.userId);
      allow create:      if isSignedIn() && isOwner(request.resource.data.userId);
    }

    // ── goals ─────────────────────────────────────────────
    match /goals/{docId} {
      allow read, write: if isSignedIn() && isOwner(resource.data.userId);
      allow create:      if isSignedIn() && isOwner(request.resource.data.userId);
    }

    // ── checkIns ──────────────────────────────────────────
    match /checkIns/{docId} {
      allow read, write: if isSignedIn() && isOwner(resource.data.userId);
      allow create:      if isSignedIn() && isOwner(request.resource.data.userId);
    }

    // ── gratitudeEntries ──────────────────────────────────
    match /gratitudeEntries/{docId} {
      allow read, write: if isSignedIn() && isOwner(resource.data.userId);
      allow create:      if isSignedIn() && isOwner(request.resource.data.userId);
    }

    // ── dailyLogs ─────────────────────────────────────────
    // Document ID: `{userId}_{YYYY-MM-DD}`
    match /dailyLogs/{docId} {
      allow read, write: if isSignedIn() && isOwner(resource.data.userId);
      allow create:      if isSignedIn() && isOwner(request.resource.data.userId);
    }

    // ── gratitude (legacy collection name) ────────────────
    match /gratitude/{docId} {
      allow read, write: if isSignedIn() && isOwner(resource.data.userId);
      allow create:      if isSignedIn() && isOwner(request.resource.data.userId);
    }
  }
}
